@using AntDesign
@using AquaSolution.Shared.UserManagements
@inject IMessageService Message
@inject NavigationManager Navigation
@inject IJSRuntime JS
<style>
    .user-modal-content {
        display: flex;
        flex-direction: row;
        gap: 24px;
        padding: 0 12px;
    }

    /* Bên trái: Avatar */
    .upload-avatar-container {
        width: 100px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding-top: 16px;
    }

    /* Bên phải: Thông tin User */
    .user-info-container {
        flex: 1;
        overflow-y: auto;
        max-height: 65vh;
    }

    .avatar-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .avatar-buttons {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        margin-top: -10px;
        gap:2px;
    }

    .role-list {
        padding-left: 20px;
        font-size: 13px;
    }

        .role-list li {
            margin-bottom: 4px;
        }

    .customModal .ant-modal-content {
       max-height:95vh !important;
    }
</style>
@{
    RenderFragment footer = @<Template>

        <Button Style="color:#808080" OnClick="@Cancel" @key="@("back")">Close</Button>

    </Template>;
}
<Modal @bind-Visible="Visible"
       Title="User Information"
       Style="z-index: 8888;width:1000px;height:78vh !important ;margin-top:-75px"
       Class="customModal"Footer="@footer">

    <div class="user-modal-content">
        <!-- Bên trái: Avatar -->
        <div class="upload-avatar-container">
            @if (IsUpLoadAvata)
            {
                <Upload @ref="uploadRef"
                        Action="@($"{Navigation.BaseUri}api/upload/avatar")"
                        ShowUploadList="false"
                        OnChange="OnUploadChanged"
                        Name="file">
                    <div class="avatar-wrapper">
                        <Avatar Src="@UserAvatarUrl" Style="width: 60px; height: 60px;margin-bottom:10px" />
                        <div class="avatar-buttons">
                            <Button Type="ButtonType.Primary" Size="ButtonSize.Small" Block="true">Upload Avatar</Button>
                        </div>
                    </div>
                </Upload>
                <Button OnClick="Zoom" Style="margin-top:5px" Size="ButtonSize.Small">
                    View Avatar
                </Button>
            }
            else
            {
                <div class="avatar-wrapper">
                    <Avatar Src="@UserAvatarUrl" Style="width: 60px; height: 60px;margin-bottom:10px" />
                    <div class="avatar-buttons">
                        <Button Size="ButtonSize.Small" OnClick="Zoom" Block="true">View Avatar</Button>
                    </div>
                </div>
            }

        </div>

        <!-- Bên phải: Thông tin User -->
        <div class="user-info-container">
            <Collapse DefaultActiveKey="@(new[] { "1" })">
                <Panel Class="customInfo" Header="Request Info" Key="1">
                    <Descriptions Style="margin-bottom: 24px;" Column="4">
                        <DescriptionsItem Span="2" Title="Full Name">@User.FullName</DescriptionsItem>
                        <DescriptionsItem Span="2" Title="Position">@User.PositionName</DescriptionsItem>
                        <DescriptionsItem Span="2" Title="Workday ID">@User.WorkDayId</DescriptionsItem>
                        <DescriptionsItem Span="2" Title="Email">@User.Email</DescriptionsItem>
                        <DescriptionsItem Span="2" Title="Phone Number">@User.PhoneNumber</DescriptionsItem>
                        <DescriptionsItem Span="2" Title="Factory">@User.FactoryName</DescriptionsItem>
                        <DescriptionsItem Span="2" Title="Manager">@User.ManagerName</DescriptionsItem>
                        <DescriptionsItem Span="2" Title="Created Date">@User.CreatedTime.ToString("dd/MM/yyyy")</DescriptionsItem>
                        <DescriptionsItem Span="2" Title="Department">@User.DepartmentName</DescriptionsItem>
                        <DescriptionsItem Span="4" Title="IsActive">@User.IsActive</DescriptionsItem>
                    </Descriptions>
                </Panel>
                <Panel Header="Roles" Key="2">
                    @if (User.Roles != null && User.Roles.Any())
                    {
                        <ul class="role-list">
                            @foreach (var role in User.Roles)
                            {
                                <li>@role.Name</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <i class="text-gray-500 text-sm">No roles assigned</i>
                    }
                </Panel>
            </Collapse>
        </div>
    </div>
</Modal>
@{
    RenderFragment footer2 = @<Template>

        <Button Style="color:#808080" OnClick="@CloseZoom" @key="@("back")">Close</Button>
        <Button OnClick="@(() => JS.InvokeVoidAsync("zoomPanHandler.zoomIn"))">Zoom +</Button>
        <Button OnClick="@(() => JS.InvokeVoidAsync("zoomPanHandler.zoomOut"))">Zoom -</Button>
    </Template>;

}
<Modal @bind-Visible="VisibleZoom"
       Style="z-index: 9999;width:1000px;height:78vh !important ;margin-top:-75px"
       Class="customModal"Footer="@footer2">

    <div id="zoom-container"
         style="overflow: hidden; width: 100%; height: 65vh; touch-action: none;">
        <img id="zoom-img"
             src="@UserAvatarUrl"
             style="transition: transform 0.1s ease-in-out; max-width: none;max-height:100%" />
    </div>

</Modal>