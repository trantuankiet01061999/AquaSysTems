@using AntDesign
@using AquaSolution.Client.Components.Administration.Icon
@using AquaSolution.Shared.ManageMedicalRooms.InventoryPeriod
@using AquaSolution.Shared.CommonDto
@inject AuthenticationStateProvider AuthStateProvider
@using AquaSolution.Shared.Enum
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient httpClient
@inject IMessageService Message

@{
    RenderFragment footer = @<Template>
    @if(!IsView)
    {
            <Button OnClick="@SaveAsync" @key="@("submit")" Type="ButtonType.Primary">
                Save
            </Button>
    }
        <Button Style="color:#808080" OnClick="@Close" @key="@("back")">
            Close
        </Button>
    </Template>;
}
<style>
    .CustomTable {
        max-height: 43vh;
        overflow: auto;
    }

    .fix-table-header table {
        border-collapse: collapse;
    }

        .fix-table-header table thead th {
            position: sticky !important;
            z-index: 8 !important;
            top:0;
            background-color: #fff;
        }

    .ant-modal-body {
        height: 85vh;
    }
    .sticky-start-btn {
    top: 21px;
    z-index: 20; /* cao hơn header */
    background-color: #1890ff;
    padding: 2px;
    border-radius:5px;
}
</style>
<Modal @bind-Visible="IsModalVisible" Style="z-index: 9999;width:1050px;margin-top:-95px" Draggable="true" Footer="@footer" Header="@null">
    <Form @ref="formRef"
          Model="@ViewInventoryPeriodDto"
          Layout="FormLayout.Vertical"
          OnFinish="SaveAsync"
          ValidateMode="FormValidateMode.Complex"
          ValidateOnChange="true">
        <!-- === Header: Thông tin nhập kho === -->
        <Card>
            <Row Gutter="16" Style="height:65px">
                <Col Span="6">
                <FormItem Label="Code">
                    <Input Disabled="true" @bind-Value="ViewInventoryPeriodDto.InventoryPeriodDto.Code" />
                </FormItem>
                </Col>
                <Col Span="9">
                <FormItem Required="true" Label="Name">
                    <Input Disabled="IsView" @bind-Value="ViewInventoryPeriodDto.InventoryPeriodDto.Name" />
                </FormItem>
                </Col>

                <Col Span="3">
                <FormItem Required="true" Label="Year">
                    <Input Disabled="IsView" @bind-Value="ViewInventoryPeriodDto.InventoryPeriodDto.Year" />
                </FormItem>
                </Col>

                <Col Span="3">
                <FormItem Required="true" Label="Month">
                    <Input Disabled="IsView" @bind-Value="ViewInventoryPeriodDto.InventoryPeriodDto.Month" />
                </FormItem>
                </Col>
                <Col Span="3">
                <FormItem Label="TimeCreated">
                    <Input Disabled="true"
                           Value="@ViewInventoryPeriodDto.InventoryPeriodDto.CreatedDate.ToString("dd/MM/yyyy")" />
                </FormItem>
                </Col>
            </Row>
            <Row Gutter="16" Style="height:45px">
                <Col Span="24">
                <FormItem Label="Note">
                    <TextArea @bind-Value="ViewInventoryPeriodDto.InventoryPeriodDto.Note" MaxRows="1" />
                </FormItem>
                </Col>

            </Row>
            @if (!IsView)
            {
                <Button Class="sticky-start-btn" OnClick="@StartAsync">
                    <Icon Type="plus" />Start Inventory
                </Button>
            }
        </Card>

        <Card>
            <div style="width:100% ;max-height:40vh; ">
                @if (IsStart || IsView)
                {
                    <Table @ref="tableRef"
                           TItem="InventoryPeriodDetailDto"
                           Size="TableSize.Small"
                           Class="CustomTable  fix-table-header"
                           PaginationPosition="false"
                           DataSource="ViewInventoryPeriodDto.InventoryPeriodDetailDtos">
                        <ColumnDefinitions Context="row2">
                            <Column Fixed="ColumnFixPlacement.Left" Width="250" TData="InventoryPeriodDetailDto" Title="ProductName">
                                <Template>
                                    <Input Disabled="true" @bind-Value="row2.ProductName"></Input>
                                </Template>
                            </Column>

                            <Column Width="90" TData="InventoryPeriodDetailDto" Title="ProductCode">
                                <Template>
                                    <Input Disabled="true" @bind-Value="row2.ProductCode"></Input>
                                </Template>
                            </Column>
                            <Column Width="70" TData="InventoryPeriodDetailDto" Title="Unit">
                                <Template>
                                    <Input Disabled="true" @bind-Value="row2.Unit"></Input>
                                </Template>
                            </Column>

                            <Column Width="60" TData="InventoryPeriodDetailDto" Title="SystemQuantity">
                                <Template>
                                    <Input Disabled="true" @bind-Value="row2.SystemQuantity"></Input>
                                </Template>
                            </Column>

                            <Column Width="60" TData="InventoryPeriodDetailDto" Title="ActualQuantity">
                                <Template>
                                    <AntDesign.InputNumber Step="1"
                                                           TValue="decimal?"
                                                           Precision="1"
                                                           Disabled ="IsView"
                                                           Value="row2.ActualQuantity"
                                                           ValueChanged="val => OnActualQuantityChanged(val, row2)"
                                                           ValueExpression="@(() => row2.ActualQuantity)" />
                                </Template>
                            </Column>

                            <Column Width="60" TData="InventoryPeriodDetailDto" Title="Distinctive">
                                <Template>
                                    <Input Disabled="true" @bind-Value="row2.RemainingValidity"></Input>
                                </Template>
                            </Column>
                            <Column Width="180" TData="InventoryPeriodDetailDto" Title="DateManufacture">
                                <Template>
                                    <Input Disabled="true" @bind-Value="row2.DateManufacture"></Input>
                                </Template>
                            </Column>
                            <Column Width="180" TData="InventoryPeriodDetailDto" Title="ExpiryDate">
                                <Template>
                                    <Input Disabled="true" @bind-Value="row2.ExpiryDate"></Input>
                                </Template>
                            </Column>

                        </ColumnDefinitions>
                    </Table>
                }
            </div>
        </Card>
    </Form>

</Modal>
