@using AntDesign
@using AquaSolution.Shared.Administration.UserManagements
@using AquaSolution.Shared.Enum;
@using AquaSolution.Shared.CommonDto;
@using AquaSolution.Shared.ManageMedicalRooms.Products
@using AquaSolution.Shared.ManageMedicalRooms.Prescriptions
@using AquaSolution.Shared.UserManagements
@using AquaSolution.Shared.ManageMedicalRooms.MedicineSupplyRequest
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject ModalService modal
@inject IMessageService Message
@{
    RenderFragment footer = @<Template>
    @if (!IsView)
    {
            <Button OnClick="@SaveAsync" @key="@( "submit" )"
                    Type="ButtonType.Primary">
                Save
            </Button>
    }
        <Button Style="color:#808080" OnClick="@Close" @key="@("back")">Close</Button>
    </Template>;
}
<style>
    .ant-card-body {
        padding: 10px !important;
    }

    .customModal .ant-modal-body {
        height: 83vh !important;
    }

    .CustomTable2 {
        overflow-y: auto;
        max-height: 29vh; 
        position: relative !important;
    }

    .fix-table-header2 table {
        border-collapse: collapse;
        width: 100%;
    }

        .fix-table-header2 table thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            background: #ffffff; /* nền trắng để không bị mờ khi scroll */
            border-bottom: 1px solid #f0f0f0;
        }


    .CustomTable {
        overflow: auto;
        height: 55vh;
    }

    .CustomTable2 {
        overflow: auto;
        height: 29vh;
    }

</style>

<Modal class="customModal" @bind-Visible="IsVisibleModal" Style="z-index: 9999;width:1050px;margin-top:-90px" Footer="@footer" Header="@null">
    <Form @ref="formRef"
          Model="@createdMedicineSupplyRequestDto"
          Layout="FormLayout.Vertical"
          OnFinish="SaveAsync"
          ValidateMode="FormValidateMode.Complex"
          ValidateOnChange="true">

        <Card>
            <Row Gutter="16" Style="height:90px">
                <Col Span="19">
                <FormItem Required="true" Label="Title">
                    <Input Disabled="IsView" @bind-Value="createdMedicineSupplyRequestDto.Title" />
                </FormItem>
                </Col>

                <Col Span="5">
                <FormItem Label="CreatedDate">
                    <Input Disabled="IsView" @bind-Value="createdMedicineSupplyRequestDto.CreatedDate" />
                </FormItem>
                </Col>

            </Row>
            <Row Gutter="16" Style="height:80px">
                <Col Span="8">
                <FormItem Required="true" Label="User Name">
                    <Select TItem="UserSelectedDto" TItemValue="UserSelectedDto"
                            DataSource="@userSelected"
                            @bind-Value="@UserValue"
                            ItemValue="c => c"
                            ItemLabel="c => c.DisplayLabel">
                    </Select>
                </FormItem>
                </Col>
                <Col Span="8">
                <FormItem Label="Email">
                    <Input Disabled="true" @bind-Value="createdMedicineSupplyRequestDto.UserRequestEmail" />
                </FormItem>
                </Col>
                <Col Span="4">
                <FormItem Label="Department">
                    <Input Disabled="true" @bind-Value="createdMedicineSupplyRequestDto.DepartmentName" />
                </FormItem>
                </Col>
                <Col Span="4">
                <FormItem Label="Factory">
                    <Input Disabled="true" @bind-Value="createdMedicineSupplyRequestDto.FactoryName" />
                </FormItem>
                </Col>
            </Row>
            <Row Gutter="16" Style="height:80px">

                <Col Span="24">
                <FormItem Label="Note">
                    <TextArea Disabled="IsView" @bind-Value="createdMedicineSupplyRequestDto.Note" MaxRows="1" />
                </FormItem>
                </Col>
            </Row>
        </Card>

        <Card>
             <div style="width:100%;overflow-x:hidden ;max-height:55vh; ">
                    @if (!IsView)
                    {
                        <Button Style=" position: sticky !important; z-index: 8 !important;top: 0;" OnClick="@AddDetailRow">
                            <Icon Type="plus" />AddDetail
                        </Button>
                    }

                </div>
            <Table @ref="@Table"
                   TItem="CreatedMedicineSupplyRequestDetailDto"
                   Size="TableSize.Small"
                   Class="CustomTable2  fix-table-header2"
                   PaginationPosition="false"
                   DataSource="createdMedicineSupplyRequestDto.CreatedMedicineSupplyRequestDetail">
                <ColumnDefinitions Context="row2">
                    <Column Width="270" TData="CreatedMedicineSupplyRequestDetailDto" Title="Product">
                        <Template>
                            <Select TItem="ProductExportDto" TItemValue="ProductExportDto"
                                    DataSource="@_products"
                                    @bind-Value="@row2.Product"
                                    ItemValue="c => c"
                                    Disabled="IsView"
                                    ItemLabel="c => c.Name">
                                <ItemTemplate Context="item">
                                    <div style="white-space: normal;">
                                        @((MarkupString)item.Title)
                                    </div>
                                    @if (item != @_products.Last())
                                    {
                                        <hr style="margin: 4px 0;height:2px" />
                                    }
                                </ItemTemplate>
                            </Select>

                        </Template>
                    </Column>

                    <Column Width="110" TData="CreatedMedicineSupplyRequestDetailDto" Title="Unit">
                        <Template>
                            <Input Disabled="true" @bind-Value="row2.Product.Unit" />
                        </Template>
                    </Column>
                    <Column Width="100" TData="CreatedMedicineSupplyRequestDetailDto" Title="Quantity">
                        <Template>
                            <AntDesign.InputNumber Step="1" TValue="decimal"
                                                   Precision="1" Disabled="true" @bind-Value="row2.Product.Quantity" />

                        </Template>
                    </Column>
                    <Column Width="100" TData="CreatedMedicineSupplyRequestDetailDto" Title="RequestedQuantity">
                        <Template>
                            <AntDesign.InputNumber Step="1" TValue="decimal"
                                                   Precision="1" Disabled="IsView" @bind-Value="row2.RequestedQuantity" />

                        </Template>
                    </Column>
                    <Column Width="130" TData="CreatedMedicineSupplyRequestDetailDto" Title="ProductType">
                        <Template>
                            <Input Disabled="true" @bind-Value="row2.Product.ProductType" />
                        </Template>
                    </Column>

                    <Column Width="150" TData="CreatedMedicineSupplyRequestDetailDto" Title="DateManufacture">
                        <Template>
                            <DatePicker Disabled="true" @bind-Value="row2.Product.ManufacturingDate" />
                        </Template>
                    </Column>
                    <Column Width="150" TData="CreatedMedicineSupplyRequestDetailDto" Title="ExpiryDate">
                        <Template>
                            <DatePicker Disabled="true" @bind-Value="row2.Product.ExpirationDate" />
                        </Template>
                    </Column>
                    <Column Width="150" TData="CreatedMedicineSupplyRequestDetailDto" Title="Note">
                        <Template>
                            <Input Disabled="true" @bind-Value="row2.Note" />
                        </Template>
                    </Column>
                    @if (!IsView)
                    {
                        <Column Fixed="ColumnFixPlacement.Right" TData="CreatedMedicineSupplyRequestDetailDto" Width="30px" Context="row">
                            <Template>
                                <div style="display: flex; flex-direction: column; gap: 4px; padding: 8px;">
                                    <Button Type="ButtonType.Text" OnClick="@(async () => await RemoveDetailRow(row2))" Style="text-align: left;">
                                        <Icon Type="delete" />
                                    </Button>
                                </div>
                            </Template>
                        </Column>
                    }
                </ColumnDefinitions>
            </Table>
        </Card>

    </Form>

</Modal>
