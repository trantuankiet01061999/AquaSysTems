@using AntDesign
@using AquaSolution.Shared.Enum;
@using AquaSolution.Shared.CommonDto;
@using AquaSolution.Shared.ManageMedicalRooms.WarehouseExports
@using AquaSolution.Shared.ManageMedicalRooms.Prescriptions
@using AquaSolution.Shared.UserManagements
@using AquaSolution.Shared.ManageMedicalRooms.Products
@using AquaSolution.Shared.ManageMedicalRooms.Treatments;
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject ModalService modal
@inject IMessageService Message
@{
    RenderFragment footer = @<Template>
    @if (!IsView)
    {
            <Button OnClick="@SaveAsync" @key="@( "submit" )"
                    Type="ButtonType.Primary">
                Save
            </Button>
    }
        <Button Style="color:#808080" OnClick="@Close" @key="@("back")">Close</Button>
    </Template>;
}
<style>
    .ant-card-body {
        padding: 10px !important;
    }

    .customModal .ant-modal-body {
        height: 83vh !important;
    }

    .fix-table-header table {
        border-collapse: collapse;
    }

        .fix-table-header table thead th {
            position: sticky !important;
            z-index: 8 !important;
            top: 0;
            background-color: #fff;
        }
</style>

<Modal class="customModal" @bind-Visible="IsVisible" Style="z-index: 9999;width:1050px;margin-top:-90px" Footer="@footer" Header="@null">
    <Form @ref="formRef"
          Model="@CreatedTreatment"
          Layout="FormLayout.Vertical"
          OnFinish="SaveAsync"
          ValidateMode="FormValidateMode.Complex"
          ValidateOnChange="true">

        <Card>
            <Row Gutter="16" Style="height:90px">
                <Col Span="12">
                <FormItem Required="true" Label="Diagnose">
                    <TextArea Disabled="IsView" @bind-Value="CreatedTreatment.Diagnose" MaxRows="2" />
                </FormItem>
                </Col>
                <Col Span="12">
                <FormItem Required="true" Label="Treatments">
                    <TextArea Disabled="IsView" @bind-Value="CreatedTreatment.Treatments" MaxRows="2" />
                </FormItem>
                </Col>
            </Row>
            <Row Gutter="16" Style="height:80px">
                <Col Span="4">
                <FormItem Label="TreatmentType">
                    <Select Style="color:red"
                            TItem="TreatmentType"
                            TItemValue="TreatmentType"
                            DataSource="@ListTreatmentType"
                            @bind-Value="@TreatmentTypeValue"
                            ItemValue="c => c"
                            Disabled="IsView"
                            ItemLabel="c => c.ToString()">
                    </Select>
                </FormItem>
                </Col>
                <Col Span="20">
                <FormItem Label="Note">

                    <TextArea Disabled="IsView" @bind-Value="CreatedTreatment.Note" MaxRows="2" />
                </FormItem>
                </Col>
            </Row>
            @if (IsPrescription)
            {
                @if (!IsView)
                {
                    <Button Style=" position: sticky !important; z-index: 8 !important;top: 0;" OnClick="@AddDetailRow">
                        <Icon Type="plus" />AddDetail
                    </Button>
                }

            }

        </Card>
        @if (IsPrescription)
        {
            <Card>
                <div style="width:100%;overflow-x:auto ;max-height:37vh; ">
                    <Table @ref="@Table"
                           TItem="CreatedPrescriptionDetailDto"
                           Size="TableSize.Small"
                           Class="CustomTable fix-table-header"
                           PaginationPosition="false"
                           DataSource="CreatedTreatment.Prescription?.CreatedPrescriptionDetail">
                        <ColumnDefinitions Context="row2">
                            <Column Width="270" TData="CreatedPrescriptionDetailDto" Title="Product">
                                <Template>
                                    <Select TItem="ProductExportDto" TItemValue="ProductExportDto"
                                            DataSource="@_products"
                                            Value="@( _products.FirstOrDefault(p => p.Id == row2.ProductId) )"
                                            ValueChanged="(val => OnProductChanged(row2, val))"
                                            ItemValue="c => c"
                                            Disabled="IsView"
                                            EnableSearch
                                            AutoClearSearchValue="false"
                                            ItemLabel="c => c.Name">
                                        <ItemTemplate Context="item">
                                            <div style="white-space: normal;">
                                                @((MarkupString)item.Title)
                                            </div>
                                            @if (item != @_products.Last())
                                            {
                                                <hr style="margin: 4px 0;height:2px" />
                                            }
                                        </ItemTemplate>
                                    </Select>

                                </Template>
                            </Column>

                            <Column Width="110" TData="CreatedPrescriptionDetailDto" Title="Unit">
                                <Template>
                                    <Input Disabled="true" @bind-Value="row2.Unit" />
                                </Template>
                            </Column>
                        <Column Width="110" TData="WarehouseExportDetailDto" Title="ActualQuantity">
                            <Template>
                                <Input Disabled="true"
                                       Value="@((_products.FirstOrDefault(p => p.Id == row2.ProductId
                                                                               && p.ExpirationDate == row2.ExpiryDate
                                                                               && p.ManufacturingDate == row2.DateManufacture)?.Quantity ?? 0).ToString())" />

                            </Template>
                        </Column>
                            <Column Width="100" TData="CreatedPrescriptionDetailDto" Title="Quantity">
                                <Template>
                                    <AntDesign.InputNumber Step="1" TValue="decimal"
                                                           Precision="1" Disabled="IsView" @bind-Value="row2.Quantity" />

                                </Template>
                            </Column>
                            <Column Width="130" TData="CreatedPrescriptionDetailDto" Title="ProductType">
                                <Template>
                                    <Input Disabled="true" @bind-Value="row2.ProductType" />
                                </Template>
                            </Column>

                            <Column Width="150" TData="CreatedPrescriptionDetailDto" Title="DateManufacture">
                                <Template>
                                    <DatePicker Disabled="true" @bind-Value="row2.DateManufacture" />
                                </Template>
                            </Column>
                            <Column Width="150" TData="CreatedPrescriptionDetailDto" Title="ExpiryDate">
                                <Template>
                                    <DatePicker Disabled="true" @bind-Value="row2.ExpiryDate" />
                                </Template>
                            </Column>
                            @if (!IsView)
                            {
                                <Column Fixed="ColumnFixPlacement.Right" TData="CreatedPrescriptionDetailDto" Width="30px" Context="row">
                                    <Template>
                                        <div style="display: flex; flex-direction: column; gap: 4px; padding: 8px;">
                                            <Button Type="ButtonType.Text" OnClick="@(async () => await RemoveDetailRow(row2))" Style="text-align: left;">
                                                <Icon Type="delete" />
                                            </Button>
                                        </div>
                                    </Template>
                                </Column>
                            }

                        </ColumnDefinitions>
                    </Table>
                </div>
            </Card>
        }

    </Form>

</Modal>
