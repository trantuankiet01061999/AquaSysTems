@using AntDesign
@using AquaSolution.Shared.ScrapManagement.FlowApprovals
@using AquaSolution.Shared.UserManagements

@{
    RenderFragment footer =
        @<div style="display:flex; gap:8px; justify-content:flex-end">
            <Button OnClick="Close">Đóng</Button>
            <Button Type="ButtonType.Primary" Loading="@_submitting" OnClick="SubmitAsync">Lưu</Button>
        </div>;
}

<Modal @bind-Visible="IsModalVisible"
       Title="@($"Cập nhật người duyệt — {_step?.Name}")"
       Style="z-index:9999; width:500px;"
       Footer="@footer"
       Draggable="true"
       OnCancel="Close">

    @if (_loading)
    {
        <div style="text-align:center; padding:40px"><Spin /></div>
    }
    else if (_step != null)
    {
        <div style="display:flex; flex-direction:column; gap:16px;">

            @* Thông tin step - readonly *@
            <div style="background:#fafafa; border:0.5px solid #f0f0f0; border-radius:6px; padding:12px; display:flex; flex-direction:column; gap:6px;">
                <div style="display:flex; gap:8px; align-items:center;">
                    <div style="width:24px; height:24px; border-radius:50%; background:#1677ff; color:#fff; font-size:11px; font-weight:600; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        @_step.Step
                    </div>
                    <span style="font-size:14px; font-weight:500; color:#222;">@_step.Name</span>
                </div>
                @if (!string.IsNullOrEmpty(_step.Description))
                {
                    <div style="font-size:12px; color:#999; padding-left:32px;">@_step.Description</div>
                }
            </div>

            @* Chọn người duyệt mới *@
            <div>
                <div style="font-size:13px; font-weight:500; color:#555; margin-bottom:6px;">Người duyệt</div>
                <Select TItem="UserDto"
                        TItemValue="Guid"
                        DataSource="@_users"
                        @bind-Value="_selectedUserId"
                        ValueName="@nameof(UserDto.Id)"
                        LabelName="@nameof(UserDto.FullName)"
                        Placeholder="-- Chọn người duyệt --"
                        Style="width:100%"
                        EnableSearch
                        AllowClear>
                    <ItemTemplate Context="user">
                        <div style="line-height:1.4">
                            <div style="font-size:13px; font-weight:500; color:#222;">
                                @user.WorkDayId — @user.FullName
                            </div>
                            <div style="font-size:11px; color:#999;">@user.Email</div>
                        </div>
                    </ItemTemplate>
                </Select>
            </div>
            @{
                var selectedUser = _users.FirstOrDefault(u => u.Id == _selectedUserId);
            }
            @if (selectedUser != null)
            {
                <div style="background:#e6f4ff; border:0.5px solid #91caff; border-radius:6px; padding:10px 12px; display:flex; flex-direction:column; gap:2px;">
                    <div style="font-size:12px; font-weight:600; color:#1677ff;">@selectedUser.WorkDayId</div>
                    <div style="font-size:13px; font-weight:500; color:#222;">@selectedUser.FullName</div>
                    <div style="font-size:11px; color:#666;">@selectedUser.Email</div>
                </div>
            }

        </div>
    }
</Modal>