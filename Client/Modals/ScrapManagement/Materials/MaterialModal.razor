@using AntDesign
@using AquaSolution.Shared.ScrapManagement.Materials
@inject HttpClient httpClient

@{
    RenderFragment footer = @<div>
        <Button OnClick="@SaveAsync"
                Type="ButtonType.Primary"
                Loading="@isSaving">
            Save
        </Button>

        <Button Style="color:#808080" OnClick="@Close">
            Close
        </Button>
    </div>;
}


<Modal @bind-Visible="IsModalVisible" Style="z-index: 9999;width:1000px;margin-top:-75px" Footer="@footer">
    <Form @ref="@formRef"
          Model="@UpdateWeight"
          Layout="FormLayout.Vertical"
          OnFinish="SaveAsync"
          ValidateMode="FormValidateMode.Complex"
          ValidateOnChange="true">

        <Row Gutter="24">
            <Col Span="24">
                <div style="background-color: #f5f5f5; padding: 12px; border-radius: 4px; margin-bottom: 16px;">
                    <p><strong>BOM Head:</strong> @SelectedMaterial?.BOMHead</p>
                    <p><strong>Code:</strong> @SelectedMaterial?.Code</p>
                    <p><strong>Name:</strong> @SelectedMaterial?.Name</p>
                </div>
            </Col>

            <Col Span="12">
                <FormItem Label="Weight (kg)">
                    <AntDesign.InputNumber Step="1" TValue="decimal"
                                           Precision="1" @bind-Value="UpdateWeight.WeightValue" />
                </FormItem>
            </Col>

            <Col Span="12">
                <FormItem Label="Start Date">
                    <DatePicker @bind-Value="UpdateWeight.StartDate"
                                Style="width: 100%;" />
                </FormItem>
            </Col>
        </Row>
    </Form>
</Modal>
