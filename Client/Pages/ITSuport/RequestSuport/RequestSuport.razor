@page "/request-it-suport"
@using AquaSolution.Client.Common
@using AquaSolution.Client.Common.GetInitial_helpers
@using AquaSolution.Client.Modals.ITSuport.RequestITSuport
@using AquaSolution.Shared.Enum
@using AquaSolution.Shared.ITSuport.RequestSuport;
@using AntDesign
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
@inject IJSRuntime JS
@using AquaSolution.Shared.UserManagements
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject GetInitial GetInitials
@inject PermissionService PermissionService

<PageTitle>IT Support Requests</PageTitle>

<div class="its-page">
    <style>
        .its-page {
            padding: 0.5rem;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        /* ── Header ── */
        .its-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
        }

        .its-header-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .its-header-left h3 {
            margin: 0;
            font-size: 18px;
            font-weight: 500;
            color: #141414;
        }

        .its-header-icon {
            width: 36px;
            height: 36px;
            background-color: #e6f4ff;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .its-header-icon .anticon {
            font-size: 18px;
            color: #1677ff;
        }

        /* ── Stats ── */
        .its-stats {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 8px;
            margin-bottom: 0.5rem;
        }

        .its-stat-card {
            background-color: #ffffff;
            border: 1px solid #d9d9d9;
            border-radius: 10px;
            padding: 5px 14px;
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .its-stat-icon-wrap {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .its-stat-label {
            font-size: 11px;
            color: #595959;
            margin-bottom: 2px;
            white-space: nowrap;
        }

        .its-stat-value {
            font-size: 22px;
            font-weight: 600;
            color: #141414;
            line-height: 1.2;
        }

        .its-stat-value.blue   { color: #1677ff; }
        .its-stat-value.orange { color: #fa8c16; }
        .its-stat-value.green  { color: #52c41a; }
        .its-stat-value.red    { color: #ff4d4f; }

        /* ── Toolbar ── */
        .its-toolbar {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 1.25rem;
        }

        .its-toolbar .ant-input-affix-wrapper {
            border-radius: 20px !important;
            font-size: 12px !important;
            width: 180px ;
        }

        .its-toolbar .ant-select-selector {
            border-radius: 20px !important;
            font-size: 12px !important;
        }

        .its-btn-action {
            border-radius: 20px !important;
            font-size: 12px !important;
            display: flex !important;
            align-items: center;
            gap: 5px;
        }

        .its-toolbar-divider {
            width: 1px;
            height: 20px;
            background: #d9d9d9;
            flex-shrink: 0;
        }

        /* ── Table ── */
        .its-table-wrap {
            border: 1px solid #d9d9d9;
            border-radius: 12px;
            overflow: hidden;
            max-height:60vh;
        }

        .its-table-wrap table thead th {
            position: sticky !important;
            top: 0;
            z-index: 8;
            background-color: #fafafa !important;
        }

        /* ── Status badge ── */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 500;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .user-cell {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .ant-table-pagination {
            position: sticky;
            bottom: 0;
            background: white;
            padding: 8px 16px;
            margin: 0 !important;
            border-top: 1px solid #d9d9d9;
            z-index: 9;
        }
    </style>

    <!-- Header -->
    <div class="its-header">
        <div class="its-header-left">
            <div class="its-header-icon">
                <Icon Type="customer-service" Theme="IconThemeType.Outline" />
            </div>
            <h3>IT Support requests</h3>
        </div>
       @*  @if (Created)
        {
            <Button Type="ButtonType.Primary"
                    Shape="ButtonShape.Round"
                    OnClick="CreatedAsync"
                    Style="display:flex;align-items:center;gap:5px;font-weight:500;">
                <Icon Type="plus" /> New ticket
            </Button>
        } *@
    </div>

    <!-- Stats -->
    <div class="its-stats">
        <div class="its-stat-card" @onclick='() => FilterByStatus("Total")'>
            <div class="its-stat-icon-wrap" style="background:#f0f5ff;">
                <Icon Type="unordered-list" Theme="IconThemeType.Outline" Style="font-size:16px;color:#1677ff;" />
            </div>
            <div>
                <div class="its-stat-label">Total</div>
                <div class="its-stat-value">@_statTotal</div>
            </div>
        </div>
        <div class="its-stat-card" @onclick='() => FilterByStatus("Open")'>
            <div class="its-stat-icon-wrap" style="background:#e6f4ff;">
                <Icon Type="clock-circle" Theme="IconThemeType.Outline" Style="font-size:16px;color:#1677ff;" />
            </div>
            <div>
                <div class="its-stat-label">Open</div>
                <div class="its-stat-value blue">@_statOpen</div>
            </div>
        </div>
     <div class="its-stat-card" @onclick='() => FilterByStatus("InProgress")'>
            <div class="its-stat-icon-wrap" style="background:#fff7e6;">
                <Icon Type="sync" Theme="IconThemeType.Outline" Style="font-size:16px;color:#fa8c16;" />
            </div>
            <div>
                <div class="its-stat-label">In progress</div>
                <div class="its-stat-value orange">@_statInProgress</div>
            </div>
        </div>
        <div class="its-stat-card"  @onclick='() => FilterByStatus("OnHold")'>
            <div class="its-stat-icon-wrap" style="background:#f5f5f5;">
                <Icon Type="pause-circle" Theme="IconThemeType.Outline" Style="font-size:16px;color:#595959;" />
            </div>
            <div>
                <div class="its-stat-label">On Hold</div>
                <div class="its-stat-value" style="color:#595959;">@_statOnHold</div>
            </div>
        </div>
        <div class="its-stat-card" @onclick='() => FilterByStatus("Resolved")'>
            <div class="its-stat-icon-wrap" style="background:#f6ffed;">
                <Icon Type="check-circle" Theme="IconThemeType.Outline" Style="font-size:16px;color:#52c41a;" />
            </div>
            <div>
                <div class="its-stat-label">Resolved</div>
                <div class="its-stat-value green">@_statResolved</div>
            </div>
        </div>
        <div class="its-stat-card"@onclick='() => FilterByStatus("Cancel")'>
            <div class="its-stat-icon-wrap" style="background:#fff1f0;">
                <Icon Type="close-circle" Theme="IconThemeType.Outline" Style="font-size:16px;color:#ff4d4f;" />
            </div>
            <div>
                <div class="its-stat-label">Cancel</div>
                <div class="its-stat-value red">@_statCancel</div>
            </div>
        </div>
    </div>

    <!-- Toolbar: tất cả filter + nút trên 1 hàng -->
    <div class="its-toolbar">
             @if (Created)
        {
            <Button Type="ButtonType.Primary"
                    Shape="ButtonShape.Round"
                    OnClick="CreatedAsync"
                    Style="display:flex;align-items:center;gap:5px;font-weight:400;">
                <Icon Type="plus" /> New ticket
            </Button>
        }
        <!-- Requester name -->
        <Input Placeholder="Requester name"
               Value="@RequesterName"
               @oninput="RequesterNameInputChanged"
               Style="font-size:12px;"
               @onkeydown="HandleKeyDown">
            <Prefix><Icon Type="user" Style="color:#bfbfbf;" /></Prefix>
        </Input>

        <!-- Requester email -->
        <Input Placeholder="Email"
               Value="@Requesteremail"
               @oninput="RequesteremailInputChanged"
               Style="font-size:12px;"
               @onkeydown="HandleKeyDown">
            <Prefix><Icon Type="mail" Style="color:#bfbfbf;" /></Prefix>
        </Input>

        <!-- Ticket code -->
        <Input Placeholder="Ticket code"
               Value="@TicketCode"
               @oninput="TicketCodeInputChanged"
               Style="font-size:12px;width:100px;"
               @onkeydown="HandleKeyDown">
            <Prefix><Icon Type="barcode" Style="color:#bfbfbf;" /></Prefix>
        </Input>

        <div class="its-toolbar-divider"></div>

        <!-- Status multi-select -->
       <Select Mode="SelectMode.Multiple"
                TItem="string"
                TItemValue="string"
                Placeholder="Status"
                @bind-Values="_selectedStatuses"
                DataSource="_statusOptions"
                ItemValue="s => s"
                ItemLabel="s => s"
                Style="min-width:190px;font-size:12px;"
                AllowClear="true" />

        <!-- Technician multi-select -->
        <Select Mode="SelectMode.Multiple"
                TItem="UserContributerDto"
                TItemValue="string"
                Placeholder="Technician"
                @bind-Values="_selectedTechnicians"
                DataSource="_listTechnician"
                ItemValue="c => c.Name ?? string.Empty"
                ItemLabel="c => c.Name ?? string.Empty"
                Style="min-width:190px;font-size:12px;"
                EnableSearch
                AllowClear="true" />

        <div class="its-toolbar-divider"></div>

        <Button Class="its-btn-action" OnClick="Search" Shape="ButtonShape.Round" Type="ButtonType.Primary">
            <Icon Type="search" /> Search
        </Button>
        <Button Class="its-btn-action" OnClick="Reset" Shape="ButtonShape.Round">
            <Icon Type="undo" /> Reset
        </Button>
    </div>
@*      @if (Created)
        {
            <Button Type="ButtonType.Primary"
                    Shape="ButtonShape.Round"
                    OnClick="CreatedAsync"
                    Style="display:flex;align-items:center;gap:5px;font-weight:500; margin-bottom:10px">
                <Icon Type="plus" /> New ticket
            </Button>
        } *@
    <!-- Table -->
    <div class="its-table-wrap">
        <Table TItem="RequestSuportDto"
               Size="TableSize.Small"
               Loading="@Loading"
               DataSource="_requestSuportFillter"
               Total="_total"
               ScrollX="1000"
               ScrollY="55vh"
               PageIndex="_currentPage"
               PageSize="_pageSize"
               OnChange="OnTableChange">
            <ColumnDefinitions Context="row">

                <PropertyColumn Width="120" Title="Ticket code" Property="c => c.TicketCode">
                    <Template>
                        <span style="font-family:monospace;font-size:12px;color:#595959;">
                            @row.TicketCode
                        </span>
                    </Template>
                </PropertyColumn>

                <PropertyColumn Width="220" Title="Title" Property="c => c.RequestTitle">
                    <Template>
                        <a href="javascript:void(0);" @onclick="() => ViewAsync(row)"
                           style="color:#1677ff;font-weight:500;">
                            @row.RequestTitle
                        </a>
                    </Template>
                </PropertyColumn>

                <PropertyColumn Width="130" Title="Status" Property="c => c.Status">
                    <Template>
                        @{
                            string color = "", bgColor = "";
                            switch (row.Status)
                            {
                                case RequestSuportStatusType.Open:
                                    color = "#1677ff"; bgColor = "#e6f4ff"; break;
                                case RequestSuportStatusType.InProgress:
                                    color = "#fa8c16"; bgColor = "#fff7e6"; break;
                                case RequestSuportStatusType.Resolved:
                                    color = "#52c41a"; bgColor = "#f6ffed"; break;
                                case RequestSuportStatusType.OnHold:
                                    color = "#595959"; bgColor = "#f5f5f5"; break;
                                case RequestSuportStatusType.Cancel:
                                    color = "#ff4d4f"; bgColor = "#fff1f0"; break;
                            }
                        }
                        <span class="status-badge" style="color:@color;background-color:@bgColor;">
                            <span class="status-dot" style="background-color:@color;"></span>
                            @row.Status
                        </span>
                    </Template>
                </PropertyColumn>

                <PropertyColumn Width="160" Title="Requested by" Property="c => c.RequestByName">
                    <Template>
                        <div class="user-cell">
                            <span style="font-size:13px;">@row.RequestByName</span>
                        </div>
                    </Template>
                </PropertyColumn>

                <PropertyColumn Width="160" Title="Technician" Property="c => c.TechnicianName">
                    <Template>
                        @if (string.IsNullOrWhiteSpace(row.TechnicianName))
                        {
                            <span style="color:#bfbfbf;font-size:12px;font-style:italic;">Unassigned</span>
                        }
                        else
                        {
                            <div class="user-cell">
                                <span style="font-size:13px;">@row.TechnicianName</span>
                            </div>
                        }
                    </Template>
                </PropertyColumn>

                <PropertyColumn Width="140" Title="Category" Property="c => c.RequestSuportCategoryName" />

                <PropertyColumn Width="115" Title="Created date" Property="c => c.CreatedDate" Format="dd/MM/yyyy HH:mm" />

                <Column Fixed="ColumnFixPlacement.Right" TData="RequestSuportDto" Width="60px" Context="row" Title="Actions">
                    <Template>
                        <Popover Title="Actions" Trigger="new Trigger[] { Trigger.Click }" Placement="Placement.Bottom">
                            <ChildContent>
                                <Button Icon="ellipsis" Size="ButtonSize.Small"
                                        Style="border-radius:6px;border:1px solid #d9d9d9;" />
                            </ChildContent>
                            <ContentTemplate>
                                <div style="display:flex;flex-direction:column;gap:2px;min-width:110px;">
                                    <Button Type="ButtonType.Text"
                                            OnClick="@(async () => await ViewAsync(row))"
                                            Style="text-align:left;font-size:13px;">
                                        <Icon Type="eye" /> Detail
                                    </Button>
                                    @{
                                        var disable3 = row.Status == RequestSuportStatusType.Resolved
                                                    || row.Status == RequestSuportStatusType.Cancel;
                                    }
                                    @if (Edit)
                                    {
                                        <Button Disabled="disable3" Type="ButtonType.Text"
                                                OnClick="@(async () => await UpdateAsync(row))"
                                                Style="text-align:left;font-size:13px;">
                                            <Icon Type="edit" /> Edit
                                        </Button>
                                    }
                                    @if (Delete)
                                    {
                                        var disible = CurrenUser!.Roles.Any(x => x.Name == "Admin") ? false : disable3;
                                        <Button Disabled="disible" Type="ButtonType.Text"
                                                OnClick="@(async () => await DeleteAsync(row.Id))"
                                                Style="text-align:left;font-size:13px;color:#ff4d4f;">
                                            <Icon Type="delete" /> Delete
                                        </Button>
                                    }
                                </div>
                            </ContentTemplate>
                        </Popover>
                    </Template>
                </Column>

            </ColumnDefinitions>
        </Table>
    </div>

</div>

<RequestITSuport OnSave="LoadData" @ref="@_requestItSuport" />
<RequestITSuportDetailModal @ref="@_requestItSuportDetailModal" />
