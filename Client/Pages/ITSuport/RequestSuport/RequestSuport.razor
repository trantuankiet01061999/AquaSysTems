@page "/request-it-suport"
@using AquaSolution.Client.Common
@using AquaSolution.Client.Common.GetInitial_helpers
@using AquaSolution.Client.Modals.ITSuport.RequestITSuport
@using AquaSolution.Shared.Enum
@using AquaSolution.Shared.ITSuport.RequestSuport;
@using AntDesign
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
@inject IJSRuntime JS
@using AquaSolution.Shared.UserManagements
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject GetInitial GetInitials

<PageTitle>RequestSuport</PageTitle>

<div class="its-page">

    <style>
        .its-page {
            padding: 1.5rem;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        /* ── Header ── */
        .its-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .its-header-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .its-header-left h3 {
            margin: 0;
            font-size: 18px;
            font-weight: 500;
        }

        .its-header-icon {
            width: 36px;
            height: 36px;
            background-color: #e6f4ff;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .its-header-icon .anticon {
            font-size: 18px;
            color: #1677ff;
        }

        /* ── Stats ── */
        /* ── Stats ── */
.its-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 1.25rem;
}

.its-stat-card {
    background-color: #ffffff;
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
}

.its-stat-icon-wrap {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.its-stat-info {
    min-width: 0;
}

.its-stat-label {
    font-size: 11px;
    color: #8c8c8c;
    margin-bottom: 2px;
    white-space: nowrap;
}

.its-stat-value {
    font-size: 22px;
    font-weight: 600;
    color: #1f1f1f;
    line-height: 1.2;
}

.its-stat-value.blue   { color: #1677ff; }
.its-stat-value.orange { color: #fa8c16; }
.its-stat-value.green  { color: #52c41a; }

        /* ── Filters ── */
        .its-filter-row1 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-bottom: 8px;
        }

        .its-filter-row2 {
            display: flex;
            gap: 8px;
            align-items: center;
            margin-bottom: 1.25rem;
        }

        .its-filter-row2 .ant-input-affix-wrapper {
            width: 160px;
            border-radius: 20px;
            font-size: 12px;
        }

        .its-filter-row1 .ant-input-affix-wrapper {
            border-radius: 20px;
            font-size: 12px;
        }

        .its-btn-action {
            border-radius: 20px !important;
            font-size: 12px !important;
            display: flex !important;
            align-items: center;
            gap: 5px;
        }

        /* ── Table ── */
        .its-table-wrap {
            border: 1px solid #f0f0f0;
            border-radius: 12px;
            overflow: hidden;
            max-height: 65vh;
        }

        .its-table-wrap .ant-table-container {
            border-radius: 0 !important;
        }

        .its-table-wrap .ant-table-content {
            overflow-x: auto !important;
            overflow-y: auto !important;
 
        }

        .its-table-wrap table thead th {
            position: sticky !important;
            top: 0;
            z-index: 8;
            background-color: #fafafa !important;
        }

        /* ── Status badge ── */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 500;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* ── Avatar ── */
        .user-avatar {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background-color: #bae0ff;
            color: #0958d9;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 500;
            flex-shrink: 0;
        }

        .user-cell {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ── Pagination fix ── */
        .ant-table-pagination {
            position: sticky;
            bottom: 0;
            background: white;
            padding: 8px 16px;
            margin: 0 !important;
            border-top: 1px solid #f0f0f0;
            z-index: 9;
        }
    </style>

    <!-- Header -->
    <div class="its-header">
        <div class="its-header-left">
            <div class="its-header-icon">
                <Icon Type="customer-service" Theme="IconThemeType.Outline" />
            </div>
            <h3>IT Support requests</h3>
        </div>
        <Button Type="ButtonType.Primary"
                Shape="ButtonShape.Round"
                OnClick="CreatedAsync"
                Style="display:flex;align-items:center;gap:5px;font-weight:500;">
            <Icon Type="plus" /> New ticket
        </Button>
    </div>

    <!-- Stats -->
