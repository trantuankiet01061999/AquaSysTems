@page "/kpi-submit"
@using AntDesign
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
@inject IJSRuntime JS
@using AquaSolution.Client.Common
@using AquaSolution.Client.Components.KPI.KPISubmit
@using AquaSolution.Client.Components.KPI.Target
@using AquaSolution.Shared.UserManagements
@using Microsoft.AspNetCore.Components.Authorization
@using AquaSolution.Shared.KPI.KPISubmit
@inject AuthenticationStateProvider AuthStateProvider
<PageTitle>RequestSuport</PageTitle>
<div class="mb-3">
    <style>
        .custom-button-type {
            height: 30px;
            font-size: 12px;
        }

        .fix-table-header table {
            border-collapse: collapse;
        }

            .fix-table-header table thead th {
                position: sticky !important;
                z-index: 8 !important;
                top: 0; 
                background-color: #fff;
            }

        .ant-table-content {
            min-height: 65vh !important;
        }

        .ant-table-pagination {
            position: fixed;
            bottom: 0;
            width: 100%;
            z-index: 999;
            background: white;
            padding: 8px;
            text-align: center;
            box-shadow: 0 -1px 4px rgba(0, 0, 0, 0.1);
            background: transparent !important;
        }

    </style>
    @if (!IsLock)
    {
        <div style="display: flex;  align-items: center; margin-bottom: 10px; ">
            <button @onclick="ViewTarget" style="margin-left:5px;border-color:#fff"><Icon Type="eye" />View Target</button>
            <button @onclick="SelectedKpi" class="btn btn-primary custom-button-type">
                <Icon Type="plus" />Selected KPI
            </button>
        </div>
    }
</div>

<div style="width:98%;overflow-x:scroll ;max-height:70vh; ">
    @{
        if (IsLock)
        {
            <div class="lock-page">
                <Icon Type="lock" Style="font-size:48px;color:#ff4d4f" />
                <h2>This page has been locked by the administrator</h2>
                <p>Please contact the administrator for more information.</p>
            </div>
        }
        else
        {
            <Table TItem="ViewKPITotalScoreDto"
                   @ref="TableRef"
                   Size="TableSize.Small"
                   Class="customTable fix-table-header"
                   DataSource="DataSource">
                <ColumnDefinitions Context="row">
                    <Column Fixed="ColumnFixPlacement.Left" TData="ViewKPITotalScoreDto" Width="50px" Context="row">
                        <Template>
                            <Popover Title="Actions" Trigger="new Trigger[] { Trigger.Click }" Placement="Placement.Bottom">
                                <ChildContent>
                                    <Button Icon="menu" />
                                </ChildContent>
                                <ContentTemplate>
                                    <div style="display: flex; flex-direction: column; gap: 4px; padding: 8px;">
                                          <Button  OnClick="@(async () => await ViewAsync(row))" Style="text-align: left;">
                                            <Icon Type="eye" /> Detail
                                        </Button>
                                    </div>
                                </ContentTemplate>
                            </Popover>
                        </Template>
                    </Column>
                    <PropertyColumn HeaderStyle="text-align: center;"  Width="300px" Title="Title" Property="c => c.Title"></PropertyColumn>
                    <PropertyColumn HeaderStyle="text-align: center;" Width="100px" Title="Status" Property="c => c.Status">
                        <Tag Color="@GetTagColor.GetTagColorCss(row.Status.ToString())">@row.Status</Tag>
                    </PropertyColumn>
                    <PropertyColumn HeaderStyle="text-align: center;" Width="200px" Title="UserName" Property="c => c.UserName"></PropertyColumn>
                    <PropertyColumn HeaderStyle="text-align: center;" Width="200px" Title="ManagerName" Property="c => c.ManagerName"></PropertyColumn>
                    <PropertyColumn HeaderStyle="text-align: center;" Width="100px" Format="0.####" Title="KPIScore" Property="c => c.KPIScore"></PropertyColumn>
                    <PropertyColumn HeaderStyle="text-align: center;" Width="100px" Format="0.####" Title="KeyTaskScore" Property="c => c.KeyTaskScore"></PropertyColumn>
                    <PropertyColumn HeaderStyle="text-align: center;" Width="100px" Format="0.####" Title="OMGScore" Property="c => c.OMGScore"></PropertyColumn>
                    <PropertyColumn HeaderStyle="text-align: center;" Width="100px" Format="0.####" Title="TotaleScore" Property="c => c.TotaleScore"></PropertyColumn>
                    <PropertyColumn HeaderStyle="text-align: center;" Width="50px" Title="Year" Property="c => c.Year"></PropertyColumn>
                  
                </ColumnDefinitions>
            </Table>
        }
    }

</div>
<SelectedKPISubmitModalrazor @ref="_selectedKpiSubmitModalrazor"></SelectedKPISubmitModalrazor>
<ApprovalTaskModal @ref="ApprovalTaskModalRef"></ApprovalTaskModal>
<TargetModal @ref="targetModal"></TargetModal>
