@page "/quarter-calculated-management"
@using AquaSolution.Client.Common
@using AquaSolution.Client.Components.Administration.Users
@using AntDesign
@inject IJSRuntime JS
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
@using AquaSolution.Client.Components.KPI.KPITask
@using AquaSolution.Client.Components.KPI.QuaterCalculated
@using AquaSolution.Shared.KPI.QuaterCalculated
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject PermissionService permissionService
<PageTitle>KPI-Task</PageTitle>
<div class="mb-3">
    <style>
        .custom-button-type {
            height: 30px;
            font-size: 12px;
        }

        .fix-table-header table {
            border-collapse: collapse;
        }

            .fix-table-header table thead th {
                position: sticky !important;
                z-index: 8 !important;
                top: 0;
                background-color: #fff;
            }

        .ant-table-content {
            min-height: 65vh !important;
        }

        .ant-table-pagination {
            position: fixed;
            bottom: 0;
            width: 100%;
            z-index: 999;
            background: white;
            padding: 8px;
            text-align: center;
            box-shadow: 0 -1px 4px rgba(0, 0, 0, 0.1);
            background: transparent !important;
        }



        .custom-label {
            background-color: #007bff;
            color: white;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            display: inline-block;
        }

            .custom-label:hover {
                background-color: #0056b3;
            }
    </style>
    <div style="display: flex;  align-items: center; margin-bottom: 10px;">
        <button @onclick="CreatedAsync" class="btn btn-primary custom-button-type">
            <Icon Type="plus" />Created
        </button>
    </div>
    <!-- #endregion -->

</div>
<div style="width:100%;overflow-x:scroll ;max-height:70vh; ">
    <Table TItem="QuaterCalculatedDto"
           @ref="tableRef"
           Size="TableSize.Small"
           Class="customTable fix-table-header"
           DataSource="DataSource">
        <ColumnDefinitions Context="row">
            <PropertyColumn Width="250px" Title="Calculated" Property="c => c.Calculated"></PropertyColumn>
            <PropertyColumn Width="100px" Title="QuarterCalculateType" Property="c => c.QuarterCalculateType"></PropertyColumn>
            <PropertyColumn Width="100px" Title="DesCription" Property="c => c.DesCription"></PropertyColumn>

            <Column Fixed="ColumnFixPlacement.Right" TData="QuaterCalculatedDto" Width="50px" Context="row">
                <Template>
                    <Popover Title="Actions" Trigger="new Trigger[] { Trigger.Click }" Placement="Placement.Bottom">
                        <ChildContent>
                            <Button Icon="menu" />
                        </ChildContent>
                        <ContentTemplate>
                            <div style="display: flex; flex-direction: column; gap: 4px; padding: 8px;">
                                <Button Type="ButtonType.Text" OnClick="@(async () => await EditAsync(row))" Style="text-align: left;">
                                    <Icon Type="edit" /> Edit
                                </Button>
                                <Button Type="ButtonType.Text" OnClick="@(async () => await DeleteAsync(row))" Style="text-align: left;">
                                    <Icon Type="delete" /> Delete
                                </Button>

                            </div>
                        </ContentTemplate>
                    </Popover>
                </Template>
            </Column>
        </ColumnDefinitions>
    </Table>
</div>
<QuaterCalculatedModal @ref="quaterCalculatedModal" OnSave="LoadData"></QuaterCalculatedModal>