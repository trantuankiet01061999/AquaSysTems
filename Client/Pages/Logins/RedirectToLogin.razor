@inject NavigationManager Nav
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage

@code {
    private DebugLogger logger;

    protected override async Task OnInitializedAsync()
    {
        logger = new DebugLogger(SessionStorage);

        await logger.LogAsync("Navigating to login page");

        var baseUri = Nav.BaseUri.TrimEnd('/');
        var targetUrl = $"{baseUri}/login";

        await logger.LogAsync($"Target URL: {targetUrl}");

        Nav.NavigateTo(targetUrl, true);
    }
}

