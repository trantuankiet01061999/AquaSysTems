@page "/clinic-check-in-management"
@using AquaSolution.Client.Modals.ManageMedicalRooms.RequestClinics
@using AquaSolution.Client.Modals.ManageMedicalRooms.Treatments
@using AquaSolution.Shared.Enum
@using AquaSolution.Shared.ManageMedicalRooms.RequestClinics
@using AquaSolution.Client.Modals.Administration.Users
@using AntDesign
@using AquaSolution.Client.Common
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
@using AquaSolution.Shared.ManageMedicalRooms.Products
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
<PageTitle>Treatments</PageTitle>
<div class="mb-3">
    <style>
        .custom-button-type {
            height: 30px;
            font-size: 12px;
        }

        .fix-table-header table {
            border-collapse: collapse;
        }

            .fix-table-header table thead th {
                position: sticky !important;
                z-index: 8 !important;
                top: 0;
                background-color: #fff;
            }

        .ant-table-pagination {
            position: fixed;
            bottom: 0;
            width: 100%;
            z-index: 999;
            background: white;
            padding: 8px;
            text-align: center;
            box-shadow: 0 -1px 4px rgba(0, 0, 0, 0.1);
             background: transparent !important; 
        }


        .ant-table-content {
            min-height: 65vh !important;
        }
    </style>
    <div style="display: flex;  align-items: center; margin-bottom: 10px; ">
        <div style="display:flex; align-items:center; gap:5px; flex-wrap:wrap;margin-left:5px">
            <Input Placeholder="Tên người yêu cầu"
                   Value="@RequesterName"
                   style="width:170px;font-size:12px"
                   @onkeydown="HandleKeyDown"
                   @oninput="RequesterNameInputChanged" />
            <button @onclick="Search" style="border-color:#fff">
                <Icon Type="search" />Search
            </button>

            <button @onclick="Reset" style="border-color:#fff">
                <Icon Type="undo" />Reset
            </button>
        </div>
    </div>
</div>
<div style="width:98%;overflow-x:scroll ;max-height:70vh; ">
    <Table TItem="MyRequestClinicDto"
           Size="TableSize.Small"
           @ref="@tableRef"
           Class="customTable fix-table-header"
           DataSource="FilterRequestClinicUser">
        <ColumnDefinitions Context="row">
            <PropertyColumn Width="400" Title="RequestTitle" Property="c => c.RequestTitle">
                <Template>
                    <a href="javascript:void(0);" @onclick="() => View(row.Id)">
                        @row.RequestTitle
                    </a>
                </Template>
            </PropertyColumn>
            <PropertyColumn Width="150" Title="Status" Property="c => c.Status" Filters="_statusFilter">
                <Tag Color="@GetTagColor.GetTagColorCss(row.Status.ToString())">@row.Status</Tag>
            </PropertyColumn>
            <PropertyColumn Width="80" Title="PurposeType" Property="c => c.PurposeType" Filters="_purposeTypeFilter"></PropertyColumn>
            <PropertyColumn Width="250" Title="Requester" Property="c => c.UserRequestName"></PropertyColumn>
            <PropertyColumn Width="130" Title="CreatedDate" Property="c => c.CreatedDate" Format="dd/MM/yyyy HH:mm"></PropertyColumn>
            <PropertyColumn Width="180" Title="Note" Property="c => c.Note"></PropertyColumn>
            <Column Fixed="ColumnFixPlacement.Right" TData="ProductDto" Width="50px" Title="" Context="row">
                @if (row.Status == StatusClinicType.Approval)
                {
                    <Template>
                        <Button Type="ButtonType.Primary" OnClick="@(async () => await Treatment(row))">
                            <Icon Type="Edit" /> Treatment
                        </Button>
                    </Template>
                }
            </Column>

        </ColumnDefinitions>
    </Table>
</div>
<Treatment OnSave="LoadData" @ref="treatment"></Treatment>
<DetailTreatmentModal @ref="DetailTreatmentModal"></DetailTreatmentModal>