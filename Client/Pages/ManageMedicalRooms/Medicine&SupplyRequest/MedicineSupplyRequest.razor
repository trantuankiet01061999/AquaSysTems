@page "/medicine-supply-request"
@using AquaSolution.Client.Modals.ManageMedicalRooms.MedicineSupplyRequest
@using AquaSolution.Shared.ManageMedicalRooms.MedicineSupplyRequest
@using AquaSolution.Client.Modals.Administration.Users
@using AntDesign
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
@using AquaSolution.Shared.ManageMedicalRooms.Products
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
<PageTitle>Product</PageTitle>
<div class="mb-3">
    <style>
        .custom-button-type {
            height: 30px;
            font-size: 12px;
        }

        .fix-table-header table {
            border-collapse: collapse;
        }

            .fix-table-header table thead th {
                position: sticky !important;
                z-index: 8 !important;
                top: 0;
                background-color: #fff;
            }

        .ant-table-content {
            min-height: 65vh !important;
        }
        .ant-table-pagination {
            position: fixed;
            bottom: 0;
            width: 100%;
            z-index: 999;
            background: white;
            padding: 8px;
            text-align: center;
            box-shadow: 0 -1px 4px rgba(0, 0, 0, 0.1);
             background: transparent !important; 
        }
    </style>
    <button @onclick="CreatedAsync" class="btn btn-primary custom-button-type">
        <Icon Type="plus" />Created
    </button>

</div>
<div style="width:100%;overflow-x:scroll ;max-height:70vh; ">
    <Table TItem="MedicineSupplyRequestDto"
           Size="TableSize.Small"
           Class="customTable fix-table-header"
           DataSource="medicineSupplyRequestDtos">
        <ColumnDefinitions Context="row">
            <PropertyColumn Fixed="ColumnFixPlacement.Left" Width="250" Title="Title" Property="c => c.Title">
                <Template>
                    <a href="javascript:void(0);" @onclick="() => ViewAsync(row)">
                        @row.Title
                    </a>
                </Template>
            </PropertyColumn>
            <PropertyColumn Width="150" Title="DepartmentName" Property="c => c.DepartmentName"></PropertyColumn>
            <PropertyColumn Width="150" Title="FactoryName" Property="c => c.FactoryName"></PropertyColumn>
            <PropertyColumn Width="200" Title="UserRequestName" Property="c => c.UserRequestName"></PropertyColumn>
            <PropertyColumn Width="150" Title="CreatedDate" Property="c => c.CreatedDate" Format="dd/MM/yyyy"></PropertyColumn>
            <PropertyColumn Width="200" Title="CreatedByName" Property="c => c.CreatedByName"></PropertyColumn>
            <PropertyColumn Width="200" Title="ApprovalName" Property="c => c.ApprovalName"></PropertyColumn>
            <PropertyColumn Width="200" Title="PharmacyManagerName" Property="c => c.PharmacyManagerName"></PropertyColumn>
            <PropertyColumn Width="250" Title="Description" Property="c => c.Description"></PropertyColumn>
            <PropertyColumn Width="350" Title="Note" Property="c => c.Note"></PropertyColumn>
        </ColumnDefinitions>
    </Table>
</div>
<MedicineSupplyRequestModal OnSave="LoadDataAsync" @ref="@medicineSupplyRequestModal"></MedicineSupplyRequestModal> 
<MedicineSupplyRequestDetailModal @ref="@medicineSupplyRequestDetailModal" />