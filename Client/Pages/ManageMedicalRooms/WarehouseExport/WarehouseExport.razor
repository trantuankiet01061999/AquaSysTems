@page "/warehouseExport-management"
@using AquaSolution.Client.Modals.ManageMedicalRooms.WarehouseExports
@using AquaSolution.Shared.ManageMedicalRooms.WarehouseExports
@using AquaSolution.Client.Modals.Administration.Users
@using AntDesign
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
@using AquaSolution.Shared.ManageMedicalRooms.Inventories
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
<PageTitle>Inventory</PageTitle>
<div class="mb-3">
    <style>
        .custom-button-type {
            height: 30px;
            font-size: 12px;
        }

        .fix-table-header table {
            
            border-collapse: collapse;
        }

            .fix-table-header table thead th {
                position: sticky !important;
                z-index: 8 !important;
                top: 0;
                background-color: #fff;
            }

        .ant-table-content {
            min-height: 65vh !important;
        }
        .ant-table-pagination {
            position: fixed;
            bottom: 0;
            width: 100%;
            z-index: 999;
            background: white;
            padding: 8px;
            text-align: center;
            box-shadow: 0 -1px 4px rgba(0, 0, 0, 0.1);
             background: transparent !important; 
        }

    </style>
   <button @onclick="ImportWarehouse" class="btn btn-primary custom-button-type">
        <Icon Type="plus" />ExportWarehouse
    </button>


</div>
<div style="width:100%;overflow-x:scroll ;max-height:70vh; ">
    <Table TItem="LoadWarehouseExportDto"
           Size="TableSize.Small"
           Class="customTable fix-table-header"
           DataSource="_listWarehouseExport">
        <ColumnDefinitions Context="row">
            <PropertyColumn Width="150" Title="Title" Property="c => c.Name">
                <Template>
                    <a href="javascript:void(0);" @onclick="() => View(row)">
                        @row.Name
                    </a>
                </Template>
            </PropertyColumn>
            <PropertyColumn Width="180" Title="Description" Property="c => c.Description"></PropertyColumn>
            <PropertyColumn Width="250" Title="Note" Property="c => c.Note"></PropertyColumn>        
            <PropertyColumn Width="150" Title="CreatedDate" Property="c => c.CreatedDate" Format="yyyy/MM/dd HH:mm"></PropertyColumn>
            <PropertyColumn Width="170" Title="CreatedBy" Property="c => c.CreatedByName"></PropertyColumn>
        </ColumnDefinitions>
    </Table>
</div>
<WarehouseExportModal OnSaved="LoadDataAsync" @ref="@_warehouseExportModal"></WarehouseExportModal> 