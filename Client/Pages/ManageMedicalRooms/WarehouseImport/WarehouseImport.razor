@page "/warehouseImport-management"
@using AquaSolution.Client.Components.ManageMedicalRooms.WarehouseImports
@using AquaSolution.Shared.ManageMedicalRooms.WarehouseImports
@using AquaSolution.Client.Components.Users
@using AntDesign
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
@using AquaSolution.Shared.ManageMedicalRooms.Inventories
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
<PageTitle>Inventory</PageTitle>
<div class="mb-3">
    <style>
        .custom-button-type {
            height: 30px;
            font-size: 12px;
        }

        .fix-table-header table {
            width: max-content;
            border-collapse: collapse;
        }

            .fix-table-header table thead th {
                position: sticky !important;
                z-index: 8 !important;
                top: 0;
                background-color: #fff;
            }

        .ant-table-pagination {
            position: fixed;
            bottom: 0;
            width: 100%;
            z-index: 999;
            background: white;
            padding: 8px;
            text-align: center;
            box-shadow: 0 -1px 4px rgba(0, 0, 0, 0.1);
            width: 173vh !important;
        }

        .ant-table-cell {
            text-align: center !important;
        }

        .ant-table-row {
            text-align: center;
        }
    </style>
   <button @onclick="ImportWarehouse" class="btn btn-primary custom-button-type">
        <Icon Type="plus" />ImportWarehouse
    </button>


</div>
<div style="width:100%;overflow-x:scroll ;max-height:75vh; ">
    <Table TItem="LoadWarehouseImportDto"
           Size="TableSize.Small"
           Class="customTable fix-table-header"
           DataSource="_listWarehouseImport">
        <ColumnDefinitions Context="row">
            <PropertyColumn Width="100" Title="Code" Property="c => c.Code"></PropertyColumn>
            <PropertyColumn Width="150" Title="Name" Property="c => c.Name">
                <Template>
                    <a href="javascript:void(0);" @onclick="() => View(row)">
                        @row.Name
                    </a>
                </Template>
            </PropertyColumn>
            <PropertyColumn Width="180" Title="Description" Property="c => c.Description"></PropertyColumn>
            <PropertyColumn Width="250" Title="Note" Property="c => c.Note"></PropertyColumn>        
            <PropertyColumn Width="150" Title="CreatedData" Property="c => c.CreatedDate" Format="yyyy/MM/dd HH:mm"></PropertyColumn>
            <PropertyColumn Width="170" Title="CreatedBy" Property="c => c.CreatedBy"></PropertyColumn>
        </ColumnDefinitions>
    </Table>
</div>
<WarehouseImportModal OnSaved="LoadDataAsync" @ref="@_warehouseImportModal"></WarehouseImportModal> 