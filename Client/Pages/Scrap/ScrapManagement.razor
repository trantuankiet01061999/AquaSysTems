@page "/scrap-history-management"
@using AquaSolution.Client.Common
@using AquaSolution.Client.Modals.Administration.Users
@using AntDesign
@inject ModalService modal
@inject NavigationManager Navigation
@using AquaSolution.Client.Modals.ScrapManagement.Materials
@using AquaSolution.Client.Modals.ScrapManagement.Scrap
@using AquaSolution.Shared.Enum.Scrap
@using AquaSolution.Shared.HRMS
@using AquaSolution.Shared.ScrapManagement.Materials
@using AquaSolution.Shared.ScrapManagement.Scrap
@using AquaSolution.Shared.UserManagements
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject PermissionService permissionService
<PageTitle>Users</PageTitle>
<div class="mb-3">
    <style>
            .custom-button-type {
                height: 30px;
                font-size: 12px;
            }

            .fix-table-header table {
                border-collapse: collapse;
            }

                .fix-table-header table thead th {
                    position: sticky !important;
                    z-index: 8 !important;
                    top: 0;
                    background-color: #fff;
                }

            .ant-table-content {
                min-height: 65vh !important;
            }

            .ant-table-pagination {
                position: fixed;
                bottom: 0;
                width: 100%;
                z-index: 999;
                background: white;
                padding: 8px;
                text-align: center;
                box-shadow: 0 -1px 4px rgba(0, 0, 0, 0.1);
                background: transparent !important;
            }



            .custom-label {
                background-color: #007bff;
                color: white;
                padding: 8px 15px;
                border-radius: 5px;
                cursor: pointer;
                display: inline-block;
            }

                .custom-label:hover {
                    background-color: #0056b3;
                }
    </style>
    <div style="display: flex;  align-items: center; margin-bottom: 10px;">
       @*  <InputFile OnChange="HandleImportExcelFile"
                   accept=".xlsx,.xls" /> *@
        <button @onclick="CreatedScrap" style="margin-left:5px;border-color:#fff"><Icon Type="undo" />Created-Scrap</button> 
        @*    <!-- #region Search -->
        <InputFile OnChange="HandleBonusYearFile"
                   accept=".xlsx,.xls" />
        <Input Placeholder="WorkDayId" Value="@WorkDayId" style="margin-left:2px;width:190px;font-size:12px" @onkeydown="HandleKeyDown" @oninput="WorkDayIdInputChanged" />
        <Input Placeholder="Full Name" Value="@FullName" style="margin-left:2px;width:190px;font-size:12px" @onkeydown="HandleKeyDown" @oninput="FullNameInputChanged" />
        <button @onclick="Search" style="margin-left:5px;border-color:#fff"><Icon Type="search" />Search</button>
        <button @onclick="Reset" style="margin-left:5px;border-color:#fff"><Icon Type="undo" />Reset</button> *@
    </div>
</div>
<div style="width:100%;overflow-x:scroll ;max-height:70vh; ">
    <Table TItem="HistoryScrapDto"
           @ref="_tableRef"
           Size="TableSize.Small"
           Bordered
           Class="customTable fix-table-header"
           DataSource="ListHistory">
        <ColumnDefinitions Context="row">
            <Column Fixed="ColumnFixPlacement.Right" TData="HistoryScrapDto" Width="50px" Context="row">
                <Template>
                    <Popover Title="Actions" Trigger="new Trigger[] { Trigger.Click }" Placement="Placement.Bottom">
                        <ChildContent>
                            <Button Icon="menu" />
                        </ChildContent>
                        <ContentTemplate>
                            <div style="display: flex; flex-direction: column; gap: 4px; padding: 8px;">
                          
                                
                          @*       @if (row.Approvals == null || !row.Approvals.Any(a => a.Status != StatusScrap.Pending))
                                {
                                    <Button Type="ButtonType.Text" OnClick="@(async () => await EditScrap(row))" Style="text-align: left;">
                                        <Icon Type="edit" /> Edit
                                    </Button>
                                } *@
                                 <Button Type="ButtonType.Text" OnClick="@(async () => await DetailScrap(row))" Style="text-align: left;">
                                    <Icon Type="eye" /> Detail
                                 </Button>

                            </div>
                        </ContentTemplate>
                    </Popover>
                </Template>
            </Column>
            <PropertyColumn Width="300px" Title="Title" Property="c => c.Title"></PropertyColumn>
            <PropertyColumn Width="300px" Title="Description" Property="c => c.Description"></PropertyColumn>
            <PropertyColumn Width="100" Title="Status" Property="c => c.Status" >
                <Tag Color="@GetTagColor.GetTagColorCss(row.Status.ToString())">@row.Status</Tag>
            </PropertyColumn>
            <PropertyColumn Width="130px" Title="Department" Property="c => c.DepartmentName"></PropertyColumn>
            <PropertyColumn Width="100px" Title="Factory" Property="c => c.FactoryName"></PropertyColumn>
            <PropertyColumn Width="200px" Title="FinalReviewer" Property="c => c.LastActionBy"></PropertyColumn>
            <PropertyColumn Width="180px" Title="FinalReviewTime" Property="c => c.LastActionDate" Format="dd/MM/yyyy HH:mm"></PropertyColumn>
            <PropertyColumn Width="200px" Title="TicketCreator" Property="c => c.CreatedByName"></PropertyColumn>
            <PropertyColumn Width="180px" Title="CreatedDate" Property="c => c.CreatedDate" Format="dd/MM/yyyy HH:mm"></PropertyColumn>

        </ColumnDefinitions>
    </Table>
</div>
<RegisterScrapModal @ref="registerScrapModal"></RegisterScrapModal>

