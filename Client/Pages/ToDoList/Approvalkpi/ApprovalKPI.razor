@page "/kpi-approval"
@using AntDesign
@inject ModalService modal
@inject NavigationManager Navigation
@inject IMessageService Message
@inject IJSRuntime JS
@using AquaSolution.Client.Common
@using AquaSolution.Client.Components.KPI.KPISubmit
@using AquaSolution.Shared.Enum.KPIType
@using AquaSolution.Shared.UserManagements
@using Microsoft.AspNetCore.Components.Authorization
@using AquaSolution.Shared.KPI.KPISubmit
@inject AuthenticationStateProvider AuthStateProvider
<PageTitle>KPI For Approval</PageTitle>
<div class="user-management-container">
    <div class="mb-3">
        <style>
            .custom-button-type {
                height: 30px;
                font-size: 12px;
            }
        </style>
    </div>
    @* <Button OnClick="InitSignalRAsync">Reload</Button> *@
    <div style="width:100%;overflow-x:scroll ;max-height:70vh; ">
        <Collapse>
            @foreach (var group in _groupedList)
            {
                <Panel Header="@($"{group.StatusName} ({group.Items.Count})")">
                    <Table TItem="ViewKPIForApprovalDto" @ref="_tableRef"
                           Bordered
                           HidePagination
                           DataSource="@group.Items">
                        <ColumnDefinitions Context="rowItem">
                            <PropertyColumn HeaderStyle="text-align: center;" Title="Step" Property="c => c.Step" Width="50" />
                            <PropertyColumn HeaderStyle="text-align: center;" Title="Position" Property="c => c.Position" Width="50" />
                            <PropertyColumn HeaderStyle="text-align: center;" Title="Title" Property="c => c.Title" />
                            <PropertyColumn HeaderStyle="text-align: center;" Width="60" Title="Month" Property="c => c.Month" />
                            <PropertyColumn HeaderStyle="text-align: center;" Title="Requester" Property="c => c.CreatedByName" Width="120" />
                            <PropertyColumn  HeaderStyle="text-align: center;" Width="60" Title="Status" Property="c => c.EApprovalStatusType">
                                <Tag Color="@GetTagColor.GetTagColorCss(rowItem.EApprovalStatusType.ToString())">@rowItem.EApprovalStatusType</Tag>
                            </PropertyColumn>
                            <PropertyColumn Sortable Title="CreatedDate" Property="c => c.CreatedDate" Format="dd/MM/yyyy HH:mm:ss" Width="180" />
                            <Column Width="70" Fixed="ColumnFixPlacement.Right" TData="ViewKPIForApprovalDto" Context="row">
                                <Template>
                                    <Popover Title="Actions" Trigger="new Trigger[] { Trigger.Click }" Placement="Placement.Bottom">
                                        <ChildContent>
                                            <Button Icon="menu" />
                                        </ChildContent>
                                        <ContentTemplate>
                                            <div style="display: flex; flex-direction: column; gap: 4px; padding: 8px;">
                                                <Button Class="btn" Type="ButtonType.Text" OnClick="@(async () => await ViewDetail(rowItem))" Style="text-align: left;">
                                                    <Icon Type="profile" /> Detail
                                                </Button>
                                                @if (rowItem.EApprovalStatusType == EApprovalStatusType.InReview)
                                                {
                                                    <Button Class="btn" Type="ButtonType.Link" OnClick="@(async () => await ApprovalAsync(rowItem.SubmitId, rowItem.Id, rowItem.DecisionMaker))" Style="text-align: left;">
                                                        <Icon Type="check" /> Approved
                                                    </Button>
                                                    <Button Class="btn" Type="ButtonType.Text" OnClick="@(async () => await RejectedAsync(rowItem.SubmitId, rowItem.Id, rowItem.DecisionMaker))" Style="text-align: left;color:red">
                                                        <Icon Type="delete" /> Rejected
                                                    </Button>
                                                }
                                            </div>
                                        </ContentTemplate>
                                    </Popover>
                                </Template>
                            </Column>

                        </ColumnDefinitions>
                    </Table>
                </Panel>
            }
        </Collapse>
    </div>
</div>
<ApprovalTaskModal IsApprovalEvent="EvenCallback" IsRejectEvent="EvenCallback" @ref="ApprovalTaskModalRef"></ApprovalTaskModal>
<HandleApprovalTask @ref="HandleApproval"></HandleApprovalTask>
