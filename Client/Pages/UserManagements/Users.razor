@page "/user-management"
@using AquaSolution.Client.Components.Users
@using AntDesign
@using AquaSolution.Shared.UserManagements
<div class="user-management-container">
    <div class="mb-3">
        <button @onclick="ShowAddUserDialog" class="btn btn-primary">
            <i class="fas fa-plus"></i> Thêm người dùng
        </button>
    </div>

    <Table TItem="UserDto"
           Size="TableSize.Small"
           Class="customTable fix-table-header"
           DataSource="users">
           	<ColumnDefinitions Context="row" >
            <PropertyColumn Title="UserName" Property="c => c.FullName"></PropertyColumn>
            <PropertyColumn Title="Email" Property="c => c.Email"></PropertyColumn>

            <Column Fixed="ColumnFixPlacement.Right" TData="UserDto" Title="Action" Context="row">
                <Template>
                    <Popover Title="Actions" Trigger="new Trigger[] { Trigger.Click }" Placement="Placement.Bottom">
                        <ChildContent>
                            <Button Icon="menu" />
                        </ChildContent>
                        <ContentTemplate>
                            <div style="display: flex; flex-direction: column; gap: 4px; padding: 8px;">
                                <Button Type="ButtonType.Text" OnClick="@(async () => await EditUser(row))" Style="text-align: left;">
                                    <Icon Type="plus" /> Edit
                                </Button>
                                <Button Type="ButtonType.Text" OnClick="@(async () => await ShowRoleDialog(row))" Style="text-align: left;">
                                    <Icon Type="edit" /> Edit
                                </Button>
                                <Button Type="ButtonType.Text" OnClick="@(async () => await ConfirmDelete(row))" Style="text-align: left;">
                                    <Icon Type="delete" /> Delete
                                </Button>
                            </div>
                        </ContentTemplate>
                    </Popover>
                </Template>
            </Column>
            </ColumnDefinitions>
    </Table>
</div>
