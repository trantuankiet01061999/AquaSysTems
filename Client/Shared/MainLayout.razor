@using System.Security.Claims
@using AntDesign
@using AquaSolution.Client.Components
@using AquaSolution.Client.Modals
@using AquaSolution.Shared.Menus
@using AquaSolution.Shared.Permissions
@using AquaSolution.Shared.UserManagements
@using Blazored.SessionStorage
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.SignalR.Client
@using System.IdentityModel.Tokens.Jwt
@inherits LayoutComponentBase
@inject AuthenticationStateProvider Auth
@inject HttpClient httpClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISessionStorageService _sessionStorage

<CascadingAuthenticationState>
    <style>
            html, body {
                height: 100%;
                margin: 0;
                padding: 0;
            }

            .layout-root {
                display: flex;
                min-height: 100vh;
                overflow: hidden;
            }

            /* ── Sidebar ── */
            .sidebar-container {
                width: 220px;
                min-width: 220px;
                flex-shrink: 0;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                overflow: hidden;
            }

                .sidebar-container::-webkit-scrollbar {
                    width: 6px;
                }

                .sidebar-container::-webkit-scrollbar-track {
                    background: #0f172a;
                }

                .sidebar-container::-webkit-scrollbar-thumb {
                    background-color: #475569;
                    border-radius: 4px;
                }

                    .sidebar-container::-webkit-scrollbar-thumb:hover {
                        background-color: #64748b;
                    }

            .ant-menu::-webkit-scrollbar {
                width: 6px;
            }

            .ant-menu::-webkit-scrollbar-thumb {
                background-color: #475569;
                border-radius: 4px;
            }

            .home-icon {
                font-size: 24px;
                cursor: pointer;
                color: #1890ff;
                padding: 6px;
                border-radius: 50%;
                transition: all 0.2s ease-in-out;
            }

                .home-icon:hover {
                    background-color: rgba(24, 144, 255, 0.1);
                    transform: scale(1.1);
                }

            .ant-menu-submenu-title {
                padding-left: 10px !important;
            }

            .ant-menu-item {
                padding-left: 30px !important;
            }

                .ant-menu-item:hover {
                    background-color: rgba(39, 69, 99) !important;
                    color: #40a9ff !important;
                    border-radius: 4px;
                    transition: all 0.2s ease-in-out;
                }

            .ant-menu-submenu-open > .ant-menu-submenu-title {
                background-color: rgba(24, 144, 255, 0.15) !important;
                color: #40a9ff !important;
                border-radius: 4px;
            }

            /* ── Main area ── */
            .main-area {
                flex: 1;
                min-width: 0;
                display: flex;
                flex-direction: column;
                overflow: hidden;
            }

            .main-header {
                height: 45px;
                flex-shrink: 0;
                background: #fff;
                box-shadow: 0 1px 4px rgba(0,0,0,0.08);
                padding: 0 16px;
                display: flex;
                align-items: center;
            }

            .main-body {
                flex: 1;
                overflow-x: auto;
                overflow-y: auto;
                background: #f5f5f5;
                padding: 4px;
            }
    </style>

    <div class="layout-root">

        <!-- Sidebar -->
        <div class="sidebar-container bg-dark text-white">
            @if (user?.Identity?.IsAuthenticated == true)
            {
                <Icon Class="home-icon" OnClick="Home" Type="home" />
                <Menu Mode="MenuMode.Inline"
                      Theme="MenuTheme.Dark"
                      Accordion="true"
                      Style="height: calc(100vh - 40px); overflow: auto;">
                    @foreach (var item in menu)
                    {
                        <SubMenu @key="item.Id">
                            <TitleTemplate>
                                <span style="display:flex;align-items:center;gap:8px;">
                                    @if (item.Icon != null)
                                    {
                                        <Icon Type="@item.Icon" />
                                    }
                                    @item.Name
                                </span>
                            </TitleTemplate>
                            <ChildContent>
                                @foreach (var page in item.Pages.OrderBy(x => x.Order))
                                {
                                    var pageValue = page;
                                    <MenuItem @key="page.Url">
                                        <NavLink class="text-white" href="@GetLink(page.Url)" Match="NavLinkMatch.All">
                                            <span style="display:flex;align-items:center;gap:8px;">
                                                @if (pageValue.Icon != null)
                                                {
                                                    <Icon Type="@pageValue.Icon" />
                                                }
                                                @pageValue.Name
                                            </span>
                                        </NavLink>
                                    </MenuItem>
                                }
                            </ChildContent>
                        </SubMenu>
                    }
                </Menu>
            }
        </div>

        <!-- Main content -->
        <div class="main-area">
            <header class="main-header">
                <HeaderComponent CurrentUser="CurrentUser" userDto="userDto" />
            </header>
            <main class="main-body">
                @Body
            </main>
        </div>

    </div>
</CascadingAuthenticationState>
