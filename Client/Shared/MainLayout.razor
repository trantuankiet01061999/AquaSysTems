@using System.Security.Claims
@using AntDesign
@using AquaSolution.Client.Components
@using AquaSolution.Shared.Menus
@using AquaSolution.Shared.Permissions
@using AquaSolution.Shared.UserManagements
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.SignalR.Client
@using System.IdentityModel.Tokens.Jwt
@inherits LayoutComponentBase
@inject AuthenticationStateProvider Auth
@inject HttpClient httpClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILocalStorageService localStorage

<CascadingAuthenticationState>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="sidebar-container bg-dark text-white" style="width: 250px; min-height: 100vh;">
            @if (user?.Identity?.IsAuthenticated == true)
            {
                <Menu Mode="MenuMode.Inline"
                      Theme="MenuTheme.Dark"
                      Style="height: 100vh; overflow: auto;">
                    <Icon Style="font-size:25px;margin-left:215px;margin-top:5px;" OnClick="Home" Type="home" />
                    @foreach (var item in menu)
                    {
                        <SubMenu @key="item.Id">
                            <TitleTemplate>
                                <span style="display: flex; align-items: center; gap: 8px;">
                                    @{
                                        if (@item.Icon != null)
                                        {
                                            <Icon Type="@item.Icon" />
                                        }
                                    }
                                    @item.Name
                                </span>
                            </TitleTemplate>

                            <ChildContent>
                                @foreach (var page in item.Pages.OrderBy(x => x.Order))
                                {
                                    var pageValue = page;
                                    <MenuItem @key="page.Url">
                                        <NavLink class="text-white" href="@GetLink(page.Url)" Match="NavLinkMatch.All">
                                            <span style="display: flex; align-items: center; gap: 8px;">
                                                @if (@pageValue.Icon != null)
                                                {
                                                    <Icon Type="@pageValue.Icon" />
                                                }
                                                @pageValue.Name
                                            </span>
                                        </NavLink>
                                    </MenuItem>
                                }
                            </ChildContent>
                        </SubMenu>
                    }
                </Menu>
            }
        </div>
        <!-- Main content -->
        <div class="flex-fill d-flex flex-column">
            <header style="height:45px" class="bg-white shadow-sm px-4 py-2 d-flex justify-content-between align-items-center">
                <HeaderComponent CurrentUser="CurrentUser" userDto="userDto" />
            </header>
            <main class="p-4 bg-light flex-fill">
                @Body
            </main>
        </div>
    </div>
</CascadingAuthenticationState>
